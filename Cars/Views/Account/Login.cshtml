@{
    ViewData["Title"] = "Showroom Portal";
}

<div class="container min-vh-100 d-flex align-items-center justify-content-center bg-light py-5">
    <div class="card border-0 rounded-4 shadow-lg overflow-hidden w-100" style="max-width: 450px;">
        <div class="bg-dark p-4 text-center text-white">
            <h3 class="fw-bold mb-1">Elite Showroom</h3>
            <p class="text-muted small mb-0">Sign in using your configuration profiles</p>
        </div>
        <div class="card-body p-4 p-sm-5 bg-white">
            <form asp-action="Login" method="post" autocomplete="off">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small py-2 rounded-3 mb-4"></div>

                <div class="mb-4">
                    <label class="form-label font-monospace text-uppercase small text-secondary tracking-wider">Email Address</label>
                    <input type="email" name="email" class="form-control rounded-3 py-2.5" placeholder="" required autocomplete="off" />
                </div>

                <div class="mb-4">
                    <label class="form-label font-monospace text-uppercase small text-secondary tracking-wider">Password</label>
                    <input type="password" name="password" class="form-control rounded-3 py-2.5" placeholder="" required autocomplete="new-password" />
                </div>

                <button type="submit" class="btn btn-primary bg-gradient w-100 rounded-pill py-2.5 fw-bold text-uppercase tracking-wide border-0 shadow-sm mt-2">
                    Authenticate
                </button>
            </form>
        </div>
        <div class="card-footer bg-light p-3 text-center border-0">
            <span class="text-muted small">Reads from local static configuration parameters</span>
        </div>
    </div>
</div>