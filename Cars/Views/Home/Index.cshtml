@model IEnumerable<Cars.Data.Models.Car>

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center mb-5">
    <h1 class="display-4">Welcome to Our Car Dealership</h1>
    <p class="lead">Find your next perfect drive below.</p>
</div>

<div class="row">
    @if (!Model.Any())
    {
        <div class="col-12 text-center">
            <p class="text-muted">No cars available at the moment. Check back soon!</p>
        </div>
    }
    else
    {
        @foreach (var car in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@car.ImageUrl" class="card-img-top" alt="@car.Make @car.Model" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">@car.Make @car.Model</h5>
                        <p class="card-text text-truncate">@car.Description</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="badge bg-secondary">@car.Category.Name</span>
                            <span class="badge bg-primary">@car.Year</span>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center">
                        <span class="h5 text-success mb-0">$@car.Price.ToString("N2")</span>
                        <a asp-controller="Cars" asp-action="Details" asp-route-id="@car.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
        }
    }
</div>