@model IEnumerable<Cars.Data.Models.Car>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
        <div>
            <h1 class="fw-bold m-0">Elite Showroom Stock</h1>
            <p class="text-muted m-0">Discover engineered precision and track-focused performance vehicles.</p>
        </div>
        <div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="me-3 fw-semibold text-dark">Welcome back, @User.Identity.Name!</span>
                @if (User.IsInRole("Administrator"))
                {
                    <a href="/Cars/Create" class="btn btn-success btn-sm fw-bold me-2">+ Add New Car</a>
                }
                <a href="/Account/Logout" class="btn btn-outline-danger btn-sm fw-bold">Sign Out</a>
            }
            else
            {
                <a href="/Account/Login" class="btn btn-dark fw-bold px-4 shadow-sm">Sign In to Claim</a>
            }
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var car in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden position-relative">

                    <span class="position-absolute top-0 end-0 m-3 badge rounded-pill @(car.IsSold ? "bg-danger" : "bg-success") px-3 py-2 fw-bold">
                        @(car.IsSold ? "Sold Out" : "Available")
                    </span>

                    <img src="@car.ImageUrl" class="card-img-top" style="height: 220px; object-fit: cover;" alt="@car.Model">

                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <div>
                            <div class="d-flex justify-content-between align-items-baseline mb-2">
                                <h4 class="card-title fw-bold m-0">@car.Make @car.Model</h4>
                                <span class="badge bg-light text-muted border px-2 py-1">@car.Year</span>
                            </div>
                            <p class="card-text text-muted small mb-4">@car.Description</p>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                            <div>
                                <span class="text-uppercase text-muted d-block" style="font-size: 0.65rem; font-weight: 700; letter-spacing: 0.5px;">MSRP Value</span>
                                <span class="text-primary fw-bold h4 m-0">$@car.Price.ToString("N0")</span>
                            </div>

                            <div>
                                @if (!User.Identity.IsAuthenticated)
                                {
                                    <a href="/Account/Login" class="btn btn-outline-secondary btn-sm fw-bold rounded-3">Sign in to buy</a>
                                }
                                else if (User.IsInRole("Administrator"))
                                {
                                    <div class="d-flex gap-1 flex-wrap">
                                        <!-- sold out btn -->
                                        <form method="post" action="/Cars/ToggleSoldStatus/@car.Id" class="d-inline">
                                            <button type="submit" class="btn btn-outline-dark btn-sm fw-bold rounded-3">
                                                @(car.IsSold ? "Mark Available" : "Mark Sold")
                                            </button>
                                        </form>

                                        <!-- edit-->
                                        <a href="/Cars/Edit/@car.Id" class="btn btn-outline-primary btn-sm fw-bold rounded-3 px-3">
                                            Edit
                                        </a>

                                       
                                        <form method="post" action="/Cars/Delete/@car.Id" class="d-inline" onsubmit="return confirm('Are you completely sure you want to permanently delete this vehicle from the showroom database?');">
                                            <button type="submit" class="btn btn-outline-danger btn-sm fw-bold rounded-3">
                                                Remove
                                            </button>
                                        </form>
                                    </div>
                                }
                                else if (User.IsInRole("User"))
                                {
                                    @if (car.IsSold)
                                    {
                                        <button class="btn btn-secondary btn-sm fw-bold rounded-3" disabled>Sold Out</button>
                                    }
                                    else
                                    {
                                        <form method="post" action="/Cars/Buy/@car.Id" class="d-inline">
                                            <button type="submit" class="btn btn-primary btn-sm fw-bold rounded-3 px-3">Buy Car</button>
                                        </form>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>