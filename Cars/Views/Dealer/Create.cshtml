@model Cars.Data.Models.Car

<div class="container mt-5">
    <h2>List a New Vehicle</h2>
    <form asp-action="Create" method="post">
        <div class="mb-3">
            <label class="form-label">Make</label>
            <input asp-for="Make" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Model</label>
            <input asp-for="Model" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Year</label>
            <input asp-for="Year" type="number" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Price</label>
            <input asp-for="Price" type="number" step="0.01" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="3" required></textarea>
        </div>
        <div class="mb-3">
            <label class="form-label">Image URL</label>
            <input asp-for="ImageUrl" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="form-label">Category</label>
            <select asp-for="CategoryId" class="form-control" required>
                @foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-success">Post Vehicle</button>
    </form>
</div>